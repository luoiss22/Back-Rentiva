# ── Django ──────────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos ──────────────────────────────────────────────────
# SQLite (por defecto en desarrollo — no definir DATABASE_URL):
#   Se usa automáticamente db.sqlite3 si DATABASE_URL no está definida.
#
# PostgreSQL (producción):
# DATABASE_URL=postgres://usuario:password@localhost:5432/rentiva_db

# ── JWT ────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── CORS ───────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (URLs del frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
